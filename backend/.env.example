NODE_ENV=development
PORT=5000
APP_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/mazingira

# JWT
JWT_SECRET=REPLACE_ME_64_CHAR_HEX
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=REPLACE_ME_ANOTHER_64_CHAR_HEX
REFRESH_TOKEN_EXPIRY=30d

# Cloudinary — get from cloudinary.com (free tier is enough)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
