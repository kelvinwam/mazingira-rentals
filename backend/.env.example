# ── App ───────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:3000

# ── PostgreSQL ─────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/mazingira

# ── Redis ──────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://...
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_STRING
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=CHANGE_THIS_ANOTHER_64_CHAR_RANDOM_STRING
REFRESH_TOKEN_EXPIRY=30d

# ── Africa's Talking (SMS) ─────────────
# Register at africastalking.com
# Use 'sandbox' for testing (codes logged to console)
AT_API_KEY=your_api_key_here
AT_USERNAME=sandbox
AT_SENDER_ID=MAZINGIRA

# ── OTP ────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=30
